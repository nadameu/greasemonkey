{
  "name": "sei-zoom-documentos",
  "gm_name": "SEI! - Zoom em documentos",
  "description": "Permite aplicar zoom apenas aos documentos do processo, sem afetar o restante da interface",
  "private": true,
  "version": "1.0.0",
  "author": "nadameu",
  "type": "module",
  "scripts": {
    "compile": "vite build",
    "dev": "run-p watch preview",
    "build": "run-s type-check compile format",
    "format": "prettier --write ../../sei-zoom-documentos.user.js",
    "preview": "vite preview --open ../../sei-zoom-documentos.user.js",
    "type-check": "tsc",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@nadameu/create-element": "workspace:^",
    "@nadameu/opaque": "workspace:^",
    "@nadameu/predicates": "workspace:^"
  }
}
